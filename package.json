{
  "name": "microblog-publisher",
  "version": "0.2.1",
  "description": "Publish Obsidian notes to micro.blog via Micropub.",
  "main": "main.js",
  "scripts": {
    "check": "tsc --noEmit --skipLibCheck",
    "dev": "node esbuild.config.mjs",
    "build": "npm run check && node esbuild.config.mjs production",
    "package": "npm run build && node scripts/package-release.mjs"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
